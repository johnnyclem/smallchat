{
  "name": "@smallchat/core",
  "version": "0.2.0",
  "description": "A message-passing tool compiler inspired by the Smalltalk/Objective-C runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/runtime.d.ts",
      "import": "./dist/runtime/runtime.js"
    },
    "./compiler": {
      "types": "./dist/compiler/compiler.d.ts",
      "import": "./dist/compiler/compiler.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./embedding": {
      "types": "./dist/embedding/local-embedder.d.ts",
      "import": "./dist/embedding/local-embedder.js"
    },
    "./channel": {
      "types": "./dist/channel/index.d.ts",
      "import": "./dist/channel/index.js"
    }
  },
  "bin": {
    "smallchat": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "models",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "dev": "tsc --watch",
    "docs:api": "typedoc --entryPoints src/index.ts --out docs/api --plugin typedoc-plugin-markdown",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "tools",
    "llm",
    "message-passing",
    "runtime",
    "smalltalk",
    "tool-compiler"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/johnnyclem/smallchat.git"
  },
  "homepage": "https://smallchat.dev",
  "author": "Johnny Clem",
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^13.0.0",
    "onnxruntime-node": "^1.20.0",
    "sqlite-vec": "^0.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
