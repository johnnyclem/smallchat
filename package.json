{
  "name": "toolkit",
  "version": "0.0.1",
  "description": "A message-passing tool compiler inspired by the Smalltalk/Objective-C runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "toolkit": "dist/cli/index.js"
  },
  "scripts": {
