{
  "id": "everything",
  "name": "Everything",
  "transportType": "mcp",
  "description": "Reference / test server with prompts, resources, and tools",
  "tools": [
    {
      "name": "echo",
      "description": "Echo back the provided message",
      "providerId": "everything",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "description": "Message to echo back" }
        },
        "required": ["message"]
      }
    },
    {
      "name": "add",
      "description": "Add two numbers together",
      "providerId": "everything",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "a": { "type": "number", "description": "First number" },
          "b": { "type": "number", "description": "Second number" }
        },
        "required": ["a", "b"]
      }
    },
    {
      "name": "longRunningOperation",
      "description": "Simulate a long-running operation with progress updates",
      "providerId": "everything",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "duration": { "type": "number", "description": "Duration in seconds" },
          "steps": { "type": "number", "description": "Number of progress steps" }
        },
        "required": ["duration"]
      }
    },
    {
      "name": "sampleLLM",
      "description": "Request an LLM to sample text based on a prompt",
      "providerId": "everything",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": { "type": "string", "description": "The prompt to send to the LLM" },
          "maxTokens": { "type": "number", "description": "Maximum number of tokens to generate" }
        },
        "required": ["prompt"]
      }
    }
  ]
}
