{
  "id": "weather-agent",
  "name": "Weather Agent",
  "transportType": "rest",
  "tools": [
    {
      "name": "get_current_weather",
      "description": "Get the current weather conditions for a specific location",
      "providerId": "weather-agent",
      "transportType": "rest",
      "inputSchema": {
        "type": "object",
        "properties": {
          "location": { "type": "string", "description": "City name or coordinates (lat,lon)" },
          "units": { "type": "string", "enum": ["metric", "imperial"], "description": "Temperature units" }
        },
        "required": ["location"]
      }
    },
    {
      "name": "get_forecast",
      "description": "Get a multi-day weather forecast for a location",
      "providerId": "weather-agent",
      "transportType": "rest",
      "inputSchema": {
        "type": "object",
        "properties": {
          "location": { "type": "string", "description": "City name or coordinates" },
          "days": { "type": "number", "description": "Number of forecast days (1-14)" },
          "units": { "type": "string", "enum": ["metric", "imperial"] }
        },
        "required": ["location"]
      }
    },
    {
      "name": "get_alerts",
      "description": "Get active weather alerts and warnings for a region",
      "providerId": "weather-agent",
      "transportType": "rest",
      "inputSchema": {
        "type": "object",
        "properties": {
          "region": { "type": "string", "description": "Region or state code" },
          "severity": { "type": "string", "enum": ["minor", "moderate", "severe", "extreme"] }
        },
        "required": ["region"]
      }
    },
    {
      "name": "search_location",
      "description": "Search for a geographic location by name and return coordinates",
      "providerId": "weather-agent",
      "transportType": "rest",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Location name to search for" }
        },
        "required": ["query"]
      }
    }
  ]
}
