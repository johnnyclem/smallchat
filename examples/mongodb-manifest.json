{
  "id": "mongodb",
  "name": "MongoDB",
  "transportType": "mcp",
  "description": "MongoDB database operations for community and Atlas deployments",
  "tools": [
    {
      "name": "find",
      "description": "Find documents in a MongoDB collection",
      "providerId": "mongodb",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "database": { "type": "string", "description": "Database name" },
          "collection": { "type": "string", "description": "Collection name" },
          "filter": { "type": "object", "description": "Query filter document" },
          "projection": { "type": "object", "description": "Fields to include/exclude" },
          "sort": { "type": "object", "description": "Sort specification" },
          "limit": { "type": "number", "description": "Maximum number of documents to return" }
        },
        "required": ["database", "collection"]
      }
    },
    {
      "name": "insert_one",
      "description": "Insert a single document into a collection",
      "providerId": "mongodb",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "database": { "type": "string", "description": "Database name" },
          "collection": { "type": "string", "description": "Collection name" },
          "document": { "type": "object", "description": "Document to insert" }
        },
        "required": ["database", "collection", "document"]
      }
    },
    {
      "name": "insert_many",
      "description": "Insert multiple documents into a collection",
      "providerId": "mongodb",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "database": { "type": "string", "description": "Database name" },
          "collection": { "type": "string", "description": "Collection name" },
          "documents": { "type": "array", "items": { "type": "object" }, "description": "Documents to insert" }
        },
        "required": ["database", "collection", "documents"]
      }
    },
    {
      "name": "update_one",
      "description": "Update a single document in a collection",
      "providerId": "mongodb",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "database": { "type": "string", "description": "Database name" },
          "collection": { "type": "string", "description": "Collection name" },
          "filter": { "type": "object", "description": "Query filter to match document" },
          "update": { "type": "object", "description": "Update operations (e.g., $set, $inc)" }
        },
        "required": ["database", "collection", "filter", "update"]
      }
    },
    {
      "name": "delete_one",
      "description": "Delete a single document from a collection",
      "providerId": "mongodb",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "database": { "type": "string", "description": "Database name" },
          "collection": { "type": "string", "description": "Collection name" },
          "filter": { "type": "object", "description": "Query filter to match document to delete" }
        },
        "required": ["database", "collection", "filter"]
      }
    },
    {
      "name": "aggregate",
      "description": "Run an aggregation pipeline on a collection",
      "providerId": "mongodb",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "database": { "type": "string", "description": "Database name" },
          "collection": { "type": "string", "description": "Collection name" },
          "pipeline": { "type": "array", "items": { "type": "object" }, "description": "Aggregation pipeline stages" }
        },
        "required": ["database", "collection", "pipeline"]
      }
    },
    {
      "name": "list_databases",
      "description": "List all databases in the MongoDB deployment",
      "providerId": "mongodb",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "list_collections",
      "description": "List all collections in a database",
      "providerId": "mongodb",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "database": { "type": "string", "description": "Database name" }
        },
        "required": ["database"]
      }
    },
    {
      "name": "create_index",
      "description": "Create an index on a collection",
      "providerId": "mongodb",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "database": { "type": "string", "description": "Database name" },
          "collection": { "type": "string", "description": "Collection name" },
          "keys": { "type": "object", "description": "Index key specification (e.g., {field: 1})" },
          "options": { "type": "object", "description": "Index options (unique, sparse, etc.)" }
        },
        "required": ["database", "collection", "keys"]
      }
    }
  ]
}
