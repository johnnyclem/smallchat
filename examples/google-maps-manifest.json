{
  "id": "google-maps",
  "name": "Google Maps",
  "transportType": "mcp",
  "description": "Location services, directions, and place information",
  "tools": [
    {
      "name": "maps_geocode",
      "description": "Convert an address into geographic coordinates",
      "providerId": "google-maps",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "address": { "type": "string", "description": "The address to geocode" }
        },
        "required": ["address"]
      }
    },
    {
      "name": "maps_reverse_geocode",
      "description": "Convert coordinates into a human-readable address",
      "providerId": "google-maps",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "latitude": { "type": "number", "description": "Latitude coordinate" },
          "longitude": { "type": "number", "description": "Longitude coordinate" }
        },
        "required": ["latitude", "longitude"]
      }
    },
    {
      "name": "maps_search_places",
      "description": "Search for places using Google Maps",
      "providerId": "google-maps",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Search query" },
          "location": { "type": "string", "description": "Center point for the search (lat,lng)" },
          "radius": { "type": "number", "description": "Search radius in meters" }
        },
        "required": ["query"]
      }
    },
    {
      "name": "maps_place_details",
      "description": "Get detailed information about a specific place",
      "providerId": "google-maps",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "placeId": { "type": "string", "description": "Google Maps place ID" }
        },
        "required": ["placeId"]
      }
    },
    {
      "name": "maps_directions",
      "description": "Get directions between two or more locations",
      "providerId": "google-maps",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "origin": { "type": "string", "description": "Starting point address or coordinates" },
          "destination": { "type": "string", "description": "Ending point address or coordinates" },
          "mode": { "type": "string", "description": "Travel mode", "enum": ["driving", "walking", "bicycling", "transit"] }
        },
        "required": ["origin", "destination"]
      }
    },
    {
      "name": "maps_distance_matrix",
      "description": "Calculate travel distance and time for multiple origin-destination pairs",
      "providerId": "google-maps",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "origins": { "type": "array", "items": { "type": "string" }, "description": "Array of origin addresses or coordinates" },
          "destinations": { "type": "array", "items": { "type": "string" }, "description": "Array of destination addresses or coordinates" },
          "mode": { "type": "string", "description": "Travel mode", "enum": ["driving", "walking", "bicycling", "transit"] }
        },
        "required": ["origins", "destinations"]
      }
    },
    {
      "name": "maps_elevation",
      "description": "Get elevation data for locations on the earth's surface",
      "providerId": "google-maps",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "locations": { "type": "array", "items": { "type": "string" }, "description": "Array of locations as lat,lng strings" }
        },
        "required": ["locations"]
      }
    }
  ]
}
