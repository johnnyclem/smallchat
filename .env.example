# smallchat environment configuration
# Copy to .env and fill in your values
# .env.local will override .env (gitignored)

# ---- Server ----
SC_PORT=3001
SC_HOST=127.0.0.1
SC_SOURCE_PATH=./examples

# ---- Logging ----
# Levels: trace, debug, info, warn, error, silent
SC_LOG_LEVEL=info
# Set to 1 for colorized human-readable output (dev only)
SC_LOG_PRETTY=0

# ---- OpenTelemetry ----
# OTLP HTTP endpoint (e.g. http://localhost:4318)
# SC_OTEL_ENDPOINT=
# Set to 1 to dump spans to stdout
# SC_OTEL_STDOUT=0

# ---- Flight Recorder ----
SC_FR_MAX_ENTRIES=500
SC_FR_FILE=smallchat-flight.ndjson

# ---- Security (never commit real values) ----
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# SC_OAUTH_CLIENT_ID=
# SC_OAUTH_CLIENT_SECRET=

# ---- Database ----
SC_DB_PATH=smallchat.db

# ---- Redis (optional caching) ----
# REDIS_URL=redis://localhost:6379
