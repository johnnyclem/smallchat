debar":"docs","previous":{"title":"ToolRuntime","permalink":"/docs/api/runtime"},"next":{"title":"ToolCompiler","permalink":"/docs/api/compiler"}},{"id":"api/mcp-server","title":"MCPServer","description":"MCPServer provides a MCP 2025-11-25 compliant HTTP server. It handles JSON-RPC requests, Server-Sent Events, and the MCP discovery endpoint.","source":"@site/docs/api/mcp-server.md","sourceDirName":"api","slug":"/api/mcp-server","permalink":"/docs/api/mcp-server","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/api/mcp-server.md","tags":[],"version":"current","frontMatter":{"title":"MCPServer","sidebar_label":"MCPServer"},"sidebar":"docs","previous":{"title":"ToolCompiler","permalink":"/docs/api/compiler"},"next":{"title":"Manifest Format","permalink":"/docs/manifests/format"}},{"id":"api/runtime","title":"ToolRuntime","description":"ToolRuntime is the top-level class. It owns the DispatchContext, manages the lifecycle of ToolClass objects, and provides the public dispatch API.","source":"@site/docs/api/runtime.md","sourceDirName":"api","slug":"/api/runtime","permalink":"/docs/api/runtime","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/api/runtime.md","tags":[],"version":"current","frontMatter":{"title":"ToolRuntime","sidebar_label":"ToolRuntime"},"sidebar":"docs","previous":{"title":"serve","permalink":"/docs/cli/serve"},"next":{"title":"Dispatch API","permalink":"/docs/api/dispatch"}},{"id":"architecture","title":"Architecture","description":"\"The big idea is messaging.\" — Alan Kay","source":"@site/docs/architecture.md","sourceDirName":".","slug":"/architecture","permalink":"/docs/architecture","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/architecture.md","tags":[],"version":"current","frontMatter":{"title":"Architecture","sidebar_label":"Architecture"},"sidebar":"docs","previous":{"title":"Example Manifests","permalink":"/docs/manifests/examples"}},{"id":"cli/compile","title":"compile","description":"Reads tool manifests from a source directory, generates semantic embeddings, groups tools into dispatch classes, and emits a compiled artifact.","source":"@site/docs/cli/compile.md","sourceDirName":"cli","slug":"/cli/compile","permalink":"/docs/cli/compile","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/cli/compile.md","tags":[],"version":"current","frontMatter":{"title":"compile","sidebar_label":"compile"},"sidebar":"docs","previous":{"title":"Overview","permalink":"/docs/cli/"},"next":{"title":"inspect","permalink":"/docs/cli/inspect"}},{"id":"cli/index","title":"CLI Reference","description":"The @smallchat/core package ships a CLI for compiling manifests, inspecting artifacts, testing dispatch resolution, and running the MCP server.","source":"@site/docs/cli/index.md","sourceDirName":"cli","slug":"/cli/","permalink":"/docs/cli/","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/cli/index.md","tags":[],"version":"current","frontMatter":{"title":"CLI Reference","sidebar_label":"Overview"},"sidebar":"docs","previous":{"title":"Method Swizzling","permalink":"/docs/concepts/swizzling"},"next":{"title":"compile","permalink":"/docs/cli/compile"}},{"id":"cli/inspect","title":"inspect","description":"Inspects a compiled artifact and prints structured information about its contents.","source":"@site/docs/cli/inspect.md","sourceDirName":"cli","slug":"/cli/inspect","permalink":"/docs/cli/inspect","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/cli/inspect.md","tags":[],"version":"current","frontMatter":{"title":"inspect","sidebar_label":"inspect"},"sidebar":"docs","previous":{"title":"compile","permalink":"/docs/cli/compile"},"next":{"title":"resolve","permalink":"/docs/cli/resolve"}},{"id":"cli/resolve","title":"resolve","description":"Tests dispatch resolution against a compiled artifact. Given a natural-language intent, prints the matched tool and confidence score. Useful for verifying that your tool descriptions produce the dispatch behaviour you expect.","source":"@site/docs/cli/resolve.md","sourceDirName":"cli","slug":"/cli/resolve","permalink":"/docs/cli/resolve","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/cli/resolve.md","tags":[],"version":"current","frontMatter":{"title":"resolve","sidebar_label":"resolve"},"sidebar":"docs","previous":{"title":"inspect","permalink":"/docs/cli/inspect"},"next":{"title":"serve","permalink":"/docs/cli/serve"}},{"id":"cli/serve","title":"serve","description":"Starts a MCP 2025-11-25 compliant HTTP server that exposes your compiled tools to any MCP-aware client.","source":"@site/docs/cli/serve.md","sourceDirName":"cli","slug":"/cli/serve","permalink":"/docs/cli/serve","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/cli/serve.md","tags":[],"version":"current","frontMatter":{"title":"serve","sidebar_label":"serve"},"sidebar":"docs","previous":{"title":"resolve","permalink":"/docs/cli/resolve"},"next":{"title":"ToolRuntime","permalink":"/docs/api/runtime"}},{"id":"concepts/dispatch","title":"Dispatch","description":"The dispatch layer is the hot path. It takes a natural-language intent, resolves it to a concrete implementation, and invokes it — either as a single call or as a streaming generator.","source":"@site/docs/concepts/dispatch.md","sourceDirName":"concepts","slug":"/concepts/dispatch","permalink":"/docs/concepts/dispatch","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/concepts/dispatch.md","tags":[],"version":"current","frontMatter":{"title":"Dispatch","sidebar_label":"Dispatch"},"sidebar":"docs","previous":{"title":"Selector Table","permalink":"/docs/concepts/selector-table"},"next":{"title":"ToolClass & ToolProxy","permalink":"/docs/concepts/tool-class"}},{"id":"concepts/index","title":"Deep Dive","description":"This section documents the internals of smallchat for engineers who want to understand or extend the runtime.","source":"@site/docs/concepts/index.md","sourceDirName":"concepts","slug":"/concepts/","permalink":"/docs/concepts/","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/concepts/index.md","tags":[],"version":"current","frontMatter":{"title":"Deep Dive","sidebar_label":"Overview"},"sidebar":"docs","previous":{"title":"Why it matters","permalink":"/docs/why-it-matters"},"next":{"title":"Selector Table","permalink":"/docs/concepts/selector-table"}},{"id":"concepts/overloading","title":"Function Overloading","description":"A single ToolSelector can map to multiple implementations with different parameter signatures. The OverloadTable resolves which implementation to call based on argument types and arity — analogous to method overloading in statically-typed languages, but resolved at runtime.","source":"@site/docs/concepts/overloading.md","sourceDirName":"concepts","slug":"/concepts/overloading","permalink":"/docs/concepts/overloading","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/concepts/overloading.md","tags":[],"version":"current","frontMatter":{"title":"Function Overloading","sidebar_label":"Function Overloading"},"sidebar":"docs","previous":{"title":"SCObject System","permalink":"/docs/concepts/sc-object"},"next":{"title":"Streaming","permalink":"/docs/concepts/streaming"}},{"id":"concepts/resolution-cache","title":"Resolution Cache","description":"The ResolutionCache is an LRU cache that stores resolved dispatches — analogous to the inline method cache in objc_msgSend. On a cache hit, dispatch skips the embedding and vector search entirely. On a cache miss, the full resolution runs and the result is stored for future calls.","source":"@site/docs/concepts/resolution-cache.md","sourceDirName":"concepts","slug":"/concepts/resolution-cache","permalink":"/docs/concepts/resolution-cache","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/concepts/resolution-cache.md","tags":[],"version":"current","frontMatter":{"title":"Resolution Cache","sidebar_label":"Resolution Cache"},"sidebar":"docs","previous":{"title":"ToolClass & ToolProxy","permalink":"/docs/concepts/tool-class"},"next":{"title":"SCObject System","permalink":"/docs/concepts/sc-object"}},{"id":"concepts/sc-object","title":"SCObject System","description":"The SCObject hierarchy is an NSObject-inspired base class for typed parameter passing. It enables runtime type checking, auto-wrapping of plain JavaScript values, and a consistent object model across dispatch boundaries.","source":"@site/docs/concepts/sc-object.md","sourceDirName":"concepts","slug":"/concepts/sc-object","permalink":"/docs/concepts/sc-object","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/concepts/sc-object.md","tags":[],"version":"current","frontMatter":{"title":"SCObject System","sidebar_label":"SCObject System"},"sidebar":"docs","previous":{"title":"Resolution Cache","permalink":"/docs/concepts/resolution-cache"},"next":{"title":"Function Overloading","permalink":"/docs/concepts/overloading"}},{"id":"concepts/selector-table","title":"Selector Table","description":"The SelectorTable is the semantic interning layer — analogous to sel_registerName in the Objective-C runtime. It ensures that semantically equivalent intent strings resolve to the same canonical ToolSelector, deduplicated by vector similarity.","source":"@site/docs/concepts/selector-table.md","sourceDirName":"concepts","slug":"/concepts/selector-table","permalink":"/docs/concepts/selector-table","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/concepts/selector-table.md","tags":[],"version":"current","frontMatter":{"title":"Selector Table","sidebar_label":"Selector Table"},"sidebar":"docs","previous":{"title":"Overview","permalink":"/docs/concepts/"},"next":{"title":"Dispatch","permalink":"/docs/concepts/dispatch"}},{"id":"concepts/streaming","title":"Streaming","description":"smallchat opens the actual provider stream. Dispatch resolves the intent once, then hands control straight to the LLM provider. Tokens arrive the moment they are generated. No waiting for the full result.","source":"@site/docs/concepts/streaming.md","sourceDirName":"concepts","slug":"/concepts/streaming","permalink":"/docs/concepts/streaming","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/concepts/streaming.md","tags":[],"version":"current","frontMatter":{"title":"Streaming","sidebar_label":"Streaming"},"sidebar":"docs","previous":{"title":"Function Overloading","permalink":"/docs/concepts/overloading"},"next":{"title":"Method Swizzling","permalink":"/docs/concepts/swizzling"}},{"id":"concepts/swizzling","title":"Method Swizzling","description":"Method swizzling replaces a tool implementation at runtime — analogous to method swizzling in Objective-C. The original implementation can be preserved and optionally called from the replacement.","source":"@site/docs/concepts/swizzling.md","sourceDirName":"concepts","slug":"/concepts/swizzling","permalink":"/docs/concepts/swizzling","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/concepts/swizzling.md","tags":[],"version":"current","frontMatter":{"title":"Method Swizzling","sidebar_label":"Method Swizzling"},"sidebar":"docs","previous":{"title":"Streaming","permalink":"/docs/concepts/streaming"},"next":{"title":"Overview","permalink":"/docs/cli/"}},{"id":"concepts/tool-class","title":"ToolClass & ToolProxy","description":"ToolClass is the provider abstraction — analogous to a class in Objective-C. It groups related tools under a single dispatch table, supports superclass chains for inheritance-based fallback, and declares protocol conformance.","source":"@site/docs/concepts/tool-class.md","sourceDirName":"concepts","slug":"/concepts/tool-class","permalink":"/docs/concepts/tool-class","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/concepts/tool-class.md","tags":[],"version":"current","frontMatter":{"title":"ToolClass & ToolProxy","sidebar_label":"ToolClass & ToolProxy"},"sidebar":"docs","previous":{"title":"Dispatch","permalink":"/docs/concepts/dispatch"},"next":{"title":"Resolution Cache","permalink":"/docs/concepts/resolution-cache"}},{"id":"getting-started","title":"Getting Started","description":"Get from zero to a running dispatch in under five minutes.","source":"@site/docs/getting-started.md","sourceDirName":".","slug":"/getting-started","permalink":"/docs/getting-started","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/getting-started.md","tags":[],"version":"current","frontMatter":{"title":"Getting Started","sidebar_label":"Getting Started"},"sidebar":"docs","previous":{"title":"Introduction","permalink":"/docs/intro"},"next":{"title":"What it does","permalink":"/docs/what-it-does"}},{"id":"intro","title":"Introduction","description":"\"The big idea is messaging.\" — Alan Kay","source":"@site/docs/intro.md","sourceDirName":".","slug":"/intro","permalink":"/docs/intro","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/intro.md","tags":[],"version":"current","frontMatter":{"title":"Introduction","sidebar_label":"Introduction","slug":"/intro"},"sidebar":"docs","next":{"title":"Getting Started","permalink":"/docs/getting-started"}},{"id":"manifests/examples","title":"Example Manifests","description":"The examples/ directory in the smallchat repository contains ready-to-use manifests for common providers. Below are four representative examples.","source":"@site/docs/manifests/examples.md","sourceDirName":"manifests","slug":"/manifests/examples","permalink":"/docs/manifests/examples","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/manifests/examples.md","tags":[],"version":"current","frontMatter":{"title":"Example Manifests","sidebar_label":"Example Manifests"},"sidebar":"docs","previous":{"title":"Manifest Format","permalink":"/docs/manifests/format"},"next":{"title":"Architecture","permalink":"/docs/architecture"}},{"id":"manifests/format","title":"Manifest Format","description":"A provider manifest is a JSON file that describes a tool provider and its tools. Manifests are the input to the compile command and the ToolCompiler API.","source":"@site/docs/manifests/format.md","sourceDirName":"manifests","slug":"/manifests/format","permalink":"/docs/manifests/format","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/manifests/format.md","tags":[],"version":"current","frontMatter":{"title":"Manifest Format","sidebar_label":"Manifest Format"},"sidebar":"docs","previous":{"title":"MCPServer","permalink":"/docs/api/mcp-server"},"next":{"title":"Example Manifests","permalink":"/docs/manifests/examples"}},{"id":"what-it-does","title":"What it does","description":"smallchat is a message-passing tool compiler for LLM-powered applications. It solves one specific problem: given a natural-language intent from an LLM, find and invoke the best-matching tool — reliably, fast, and without hallucination.","source":"@site/docs/what-it-does.md","sourceDirName":".","slug":"/what-it-does","permalink":"/docs/what-it-does","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/what-it-does.md","tags":[],"version":"current","frontMatter":{"title":"What it does","sidebar_label":"What it does"},"sidebar":"docs","previous":{"title":"Getting Started","permalink":"/docs/getting-started"},"next":{"title":"Why it matters","permalink":"/docs/why-it-matters"}},{"id":"why-it-matters","title":"Why it matters","description":"The problem: tool proliferation","source":"@site/docs/why-it-matters.md","sourceDirName":".","slug":"/why-it-matters","permalink":"/docs/why-it-matters","draft":false,"unlisted":false,"editUrl":"https://github.com/johnnyclem/smallchat/tree/main/packages/docs/docs/why-it-matters.md","tags":[],"version":"current","frontMatter":{"title":"Why it matters","sidebar_label":"Why it matters"},"sidebar":"docs","previous":{"title":"What it does","permalink":"/docs/what-it-does"},"next":{"title":"Overview","permalink":"/docs/concepts/"}}],"drafts":[],"sidebars":{"docs":[{"type":"doc","id":"intro"},{"type":"doc","id":"getting-started"},{"type":"doc","id":"what-it-does"},{"type":"doc","id":"why-it-matters"},{"type":"category","label":"Deep Dive","items":[{"type":"doc","id":"concepts/index"},{"type":"doc","id":"concepts/selector-table"},{"type":"doc","id":"concepts/dispatch"},{"type":"doc","id":"concepts/tool-class"},{"type":"doc","id":"concepts/resolution-cache"},{"type":"doc","id":"concepts/sc-object"},{"type":"doc","id":"concepts/overloading"},{"type":"doc","id":"concepts/streaming"},{"type":"doc","id":"concepts/swizzling"}],"collapsed":true,"collapsible":true},{"type":"category","label":"CLI Reference","items":[{"type":"doc","id":"cli/index"},{"type":"doc","id":"cli/compile"},{"type":"doc","id":"cli/inspect"},{"type":"doc","id":"cli/resolve"},{"type":"doc","id":"cli/serve"}],"collapsed":true,"collapsible":true},{"type":"category","label":"API Reference","items":[{"type":"doc","id":"api/runtime"},{"type":"doc","id":"api/dispatch"},{"type":"doc","id":"api/compiler"},{"typ