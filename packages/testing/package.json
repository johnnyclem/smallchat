{
  "name": "@smallchat/testing",
  "version": "0.1.0",
  "description": "Testing utilities and mocks for smallchat tool dispatch",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
