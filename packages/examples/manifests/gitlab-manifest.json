{
  "id": "gitlab",
  "name": "GitLab",
  "transportType": "mcp",
  "description": "GitLab API integration for project management and repository operations",
  "tools": [
    {
      "name": "list_projects",
      "description": "List projects accessible by the authenticated user",
      "providerId": "gitlab",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "search": { "type": "string", "description": "Search query to filter projects" },
          "owned": { "type": "boolean", "description": "Only show owned projects" },
          "perPage": { "type": "number", "description": "Number of results per page" }
        }
      }
    },
    {
      "name": "get_project",
      "description": "Get details of a specific project",
      "providerId": "gitlab",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "projectId": { "type": "string", "description": "Project ID or URL-encoded path" }
        },
        "required": ["projectId"]
      }
    },
    {
      "name": "list_merge_requests",
      "description": "List merge requests for a project",
      "providerId": "gitlab",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "projectId": { "type": "string", "description": "Project ID or URL-encoded path" },
          "state": { "type": "string", "description": "Filter by state", "enum": ["opened", "closed", "merged", "all"] }
        },
        "required": ["projectId"]
      }
    },
    {
      "name": "create_issue",
      "description": "Create a new issue in a project",
      "providerId": "gitlab",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "projectId": { "type": "string", "description": "Project ID or URL-encoded path" },
          "title": { "type": "string", "description": "Issue title" },
          "description": { "type": "string", "description": "Issue description in markdown" },
          "labels": { "type": "string", "description": "Comma-separated label names" },
          "assigneeIds": { "type": "array", "items": { "type": "number" }, "description": "Array of user IDs to assign" }
        },
        "required": ["projectId", "title"]
      }
    },
    {
      "name": "create_merge_request",
      "description": "Create a new merge request",
      "providerId": "gitlab",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "projectId": { "type": "string", "description": "Project ID or URL-encoded path" },
          "title": { "type": "string", "description": "Merge request title" },
          "sourceBranch": { "type": "string", "description": "Source branch name" },
          "targetBranch": { "type": "string", "description": "Target branch name" },
          "description": { "type": "string", "description": "Merge request description" }
        },
        "required": ["projectId", "title", "sourceBranch", "targetBranch"]
      }
    },
    {
      "name": "list_pipelines",
      "description": "List CI/CD pipelines for a project",
      "providerId": "gitlab",
      "transportType": "mcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "projectId": { "type": "string", "description": "Project ID or URL-encoded path" },
          "status": { "type": "string", "description": "Filter by pipeline status", "enum": ["running", "pending", "success", "failed", "canceled", "skipped"] },
          "ref": { "type": "string", "description": "Filter by branch or tag name" }
        },
        "required": ["projectId"]
      }
    }
  ]
}
