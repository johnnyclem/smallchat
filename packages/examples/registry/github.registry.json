{
  "$schema": "https://smallchat.dev/schema/registry-entry.json",
  "id": "github",
  "name": "GitHub",
  "description": "Interact with GitHub repositories, issues, pull requests, and code search",
  "longDescription": "The GitHub MCP server provides tools for interacting with the GitHub API. Search code across repositories, create and manage issues, list pull requests, and more. Requires a GitHub personal access token with appropriate scopes.",
  "version": "1.0.0",
  "author": "Anthropic",
  "license": "MIT",
  "repository": "https://github.com/modelcontextprotocol/servers",
  "homepage": "https://modelcontextprotocol.io/docs/servers/github",
  "icon": "github",
  "categories": ["developer-tools"],
  "tags": ["github", "git", "vcs", "code-review", "issues", "pull-requests"],
  "install": {
    "method": "npx",
    "package": "@modelcontextprotocol/server-github",
    "runtime": "node",
    "runtimeVersion": ">=18.0.0",
    "env": [
      {
        "name": "GITHUB_TOKEN",
        "description": "GitHub personal access token",
        "required": true,
        "secret": true,
        "helpUrl": "https://github.com/settings/tokens"
      }
    ]
  },
  "manifest": {
    "id": "github",
    "name": "GitHub",
    "transportType": "mcp",
    "tools": [
      {
        "name": "search_code",
        "description": "Search for code across GitHub repositories",
        "providerId": "github",
        "transportType": "mcp",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "Search query" },
            "language": { "type": "string", "description": "Programming language filter" },
            "repo": { "type": "string", "description": "Repository to search in" }
          },
          "required": ["query"]
        }
      },
      {
        "name": "create_issue",
        "description": "Create a new issue in a GitHub repository",
        "providerId": "github",
        "transportType": "mcp",
        "inputSchema": {
          "type": "object",
          "properties": {
            "title": { "type": "string", "description": "Issue title" },
            "body": { "type": "string", "description": "Issue body in markdown" },
            "repo": { "type": "string", "description": "Repository (owner/name)" },
            "labels": { "type": "string", "description": "Comma-separated labels" }
          },
          "required": ["title", "repo"]
        }
      },
      {
        "name": "list_pull_requests",
        "description": "List pull requests for a repository",
        "providerId": "github",
        "transportType": "mcp",
        "inputSchema": {
          "type": "object",
          "properties": {
            "repo": { "type": "string", "description": "Repository (owner/name)" },
            "state": { "type": "string", "description": "Filter by state", "enum": ["open", "closed", "all"] },
            "sort": { "type": "string", "description": "Sort by", "enum": ["created", "updated", "popularity"] }
          },
          "required": ["repo"]
        }
      }
    ]
  },
  "defaultHints": {
    "namespace": "vcs.github",
    "selectorHint": "GitHub source code management and collaboration tools"
  },
  "defaultToolHints": {
    "search_code": {
      "aliases": ["find code", "grep repository"],
      "priority": 1.2
    }
  },
  "capabilities": {
    "resources": true,
    "prompts": false,
    "streaming": false
  }
}
